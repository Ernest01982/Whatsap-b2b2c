# Supabase Configuration
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (Server-side only - KEEP SECRET)
# Get this from Supabase project settings > API > Service Role Key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application URL (used for OAuth redirects and email links)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# WhatsApp Business API (Optional - for payment receipts)
# Get these from Meta Business Suite > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Resend Email API (Optional - for email invoices)
# Get this from https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
